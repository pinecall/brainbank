{
    "name": "brainbank",
    "version": "0.1.0",
    "description": "Semantic knowledge bank for AI agents — code indexing, git history, learned patterns, vector search",
    "type": "module",
    "main": "src/index.ts",
    "bin": {
        "brainbank": "./src/integrations/cli.ts"
    },
    "exports": {
        ".": "./src/index.ts",
        "./code": "./src/plugins/code.ts",
        "./git": "./src/plugins/git.ts",
        "./docs": "./src/plugins/docs.ts",
        "./notes": "./src/plugins/notes.ts",
        "./memory": "./src/plugins/memory.ts"
    },
    "files": [
        "src/",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "test": "node --import tsx test/run.ts",
        "test:integration": "node --import tsx test/run.ts --integration",
        "test:verbose": "node --import tsx test/run.ts --verbose"
    },
    "engines": {
        "node": ">=18"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pinecall/brainbank.git"
    },
    "keywords": [
        "ai",
        "agent",
        "semantic-memory",
        "vector-search",
        "knowledge-base",
        "embeddings",
        "hnsw",
        "typescript"
    ],
    "author": "Bernardo Castro <bernardo@pinecall.io>",
    "license": "MIT",
    "dependencies": {
        "better-sqlite3": "^11.8.1",
        "hnswlib-node": "^3.0.0"
    },
    "optionalDependencies": {
        "@xenova/transformers": "^2.17.2"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
