{
    "name": "brainbank",
    "version": "0.1.0",
    "description": "Semantic knowledge bank for AI agents — code indexing, git history, learned patterns, vector search",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "brainbank": "./dist/cli.js"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./code": {
            "import": "./dist/code.js",
            "types": "./dist/code.d.ts"
        },
        "./git": {
            "import": "./dist/git.js",
            "types": "./dist/git.d.ts"
        },
        "./docs": {
            "import": "./dist/docs.js",
            "types": "./dist/docs.d.ts"
        },
        "./notes": {
            "import": "./dist/notes.js",
            "types": "./dist/notes.d.ts"
        },
        "./memory": {
            "import": "./dist/memory.js",
            "types": "./dist/memory.d.ts"
        }
    },
    "files": [
        "dist/",
        "bin/",
        "LICENSE",
        "README.md",
        "docs/"
    ],
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "npm run build",
        "test": "node --import tsx test/run.ts",
        "test:integration": "node --import tsx test/run.ts --integration",
        "test:verbose": "node --import tsx test/run.ts --verbose",
        "dev": "tsx src/integrations/cli.ts"
    },
    "engines": {
        "node": ">=18"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pinecall/brainbank.git"
    },
    "keywords": [
        "ai",
        "agent",
        "semantic-memory",
        "vector-search",
        "knowledge-base",
        "embeddings",
        "hnsw",
        "typescript"
    ],
    "author": "Bernardo Castro <bernardo@pinecall.io>",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "better-sqlite3": "^11.8.1",
        "hnswlib-node": "^3.0.0",
        "zod": "^4.3.6"
    },
    "optionalDependencies": {
        "@xenova/transformers": "^2.17.2",
        "node-llama-cpp": "^3.18.1",
        "simple-git": "^3.27.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22.0.0",
        "tsup": "^8.4.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
